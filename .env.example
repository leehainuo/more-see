# 应用基础配置
APP_NAME=More See
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# 模型提供方开关
# 当前项目默认全部走火山，通常保持 volcengine 即可
ASR_PROVIDER=volcengine
VISION_PROVIDER=volcengine
LLM_PROVIDER=volcengine
TTS_PROVIDER=volcengine

# 豆包语音合成 TTS
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_shuangkuaisisi_moon_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000

# 如果没有统一语音 API Key，可回退填写旧版 ASR
VOLCENGINE_ASR_ACCESS_TOKEN=
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# 火山方舟文本 / 视觉模型
# ARK_API_KEY 用于文本与图片理解模型调用
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_LLM_MODEL=doubao-seed-1-6-251015
ARK_VISION_MODEL=doubao-seed-1-6-vision-250815
