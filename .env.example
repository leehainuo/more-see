# 应用基础配置
APP_NAME=More See
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# 模型提供方开关
# 当前项目默认全部走火山，通常保持 volcengine 即可
ASR_PROVIDER=volcengine
VISION_PROVIDER=volcengine
LLM_PROVIDER=volcengine
TTS_PROVIDER=volcengine

# 豆包语音统一鉴权
# 参考文档：https://www.volcengine.com/docs/6561/1816214
# 新版控制台统一使用 API Key，无需再填写 AppId / AccessToken
VOLCENGINE_SPEECH_API_KEY=

# 豆包语音合成 TTS
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_vv_uranus_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000

# 豆包流式语音识别 ASR
# 当前前端默认上传 16k PCM 音频分片
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
VOLCENGINE_ASR_LANGUAGE=zh-CN

# 语音 WebSocket SSL
# 默认使用项目内置 certifi 证书链；若本机/企业网络要求自定义 CA，可填写绝对路径覆盖
VOLCENGINE_SSL_CERT_FILE=

# 火山方舟文本 / 视觉模型
# ARK_API_KEY 用于文本与图片理解模型调用
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_LLM_MODEL=doubao-seed-1-6-251015
ARK_VISION_MODEL=doubao-seed-1-6-vision-250815

# MySQL 持久化存储
MYSQL_DSN=mysql+asyncmy://moresee:moresee@127.0.0.1:3306/more_see?charset=utf8mb4
MYSQL_ECHO=false
MYSQL_AUTO_CREATE_TABLES=true

# 登录鉴权
AUTH_JWT_SECRET=dev-only-secret
AUTH_JWT_EXPIRE_SECONDS=604800
AUTH_COOKIE_NAME=moresee_token
AUTH_ALLOW_REGISTER=true

# Redis
REDIS_DSN=redis://127.0.0.1:6379/0
REDIS_LOCK_TTL_SECONDS=30
